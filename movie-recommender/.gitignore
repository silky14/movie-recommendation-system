# ─────────────────────────────────────────────
# Movie Recommender — .gitignore
# ─────────────────────────────────────────────

# Dataset files (too large for GitHub, ~15 MB each)
data/*.csv
data/*.zip
data/*.gz

# Trained model artifacts (regenerated by setup.py)
# Uncomment the lines below to EXCLUDE models from git.
# By default they are included so the app works after cloning.
models/


# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Virtual environments
venv/
.venv/
env/
ENV/
.env

# Jupyter Notebooks checkpoints
.ipynb_checkpoints/
*.ipynb

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# IDE / editor files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Streamlit
.streamlit/secrets.toml

# OS
.DS_Store
desktop.ini
